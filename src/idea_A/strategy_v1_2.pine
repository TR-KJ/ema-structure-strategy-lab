//@version=6
strategy("EMA Structure Pullback Strategy v1.2", overlay = true, initial_capital = 1000000, default_qty_type = strategy.percent_of_equity, default_qty_value = 2, commission_type = strategy.commission.percent, commission_value = 0.04, slippage = 2, pyramiding = 0, process_orders_on_close = false, calc_on_every_tick = false, max_lines_count = 500, max_labels_count = 500)

//====================================================
// Inputs
//====================================================

emaFastLen = input.int(20, "EMA Fast Length", minval = 1)
emaMidLen = input.int(50, "EMA Middle Length", minval = 1)
emaSlowLen = input.int(200, "EMA Slow Length", minval = 1)

pullbackLookback = input.int(10, "Pullback Lookback Bars", minval = 1)

useCooldown = input.bool(true, "Use Cooldown")
cooldownBars = input.int(10, "Cooldown Bars", minval = 1)

riskLookback = input.int(10, "SL Lookback Bars", minval = 1)
rr = input.float(1.0, "RR", minval = 0.1, step = 0.1)

useMinRiskFilter = input.bool(true, "Use Min Risk Filter")
minRiskTicks = input.int(30, "Min Risk Ticks", minval = 1)

showEma = input.bool(true, "Show EMA")
showSetupBg = input.bool(true, "Show Setup Background")
showSignals = input.bool(true, "Show Trigger Signals")

//====================================================
// EMA
//====================================================

emaFast = ta.ema(close, emaFastLen)
emaMid = ta.ema(close, emaMidLen)
emaSlow = ta.ema(close, emaSlowLen)

plot(showEma ? emaFast : na, "EMA Fast", color = color.orange, linewidth = 2)
plot(showEma ? emaMid : na, "EMA Middle", color = color.blue, linewidth = 2)
plot(showEma ? emaSlow : na, "EMA Slow", color = color.gray, linewidth = 2)

//====================================================
// Setup Conditions
//====================================================

emaBullStructure = false
emaBearStructure = false

if emaFast > emaMid
    if emaMid > emaSlow
        emaBullStructure := true

if emaFast < emaMid
    if emaMid < emaSlow
        emaBearStructure := true

longPricePosition = close > emaMid
shortPricePosition = close < emaMid

longPullbackDistance = low - emaFast
shortPullbackDistance = high - emaFast

longPullbackTouched = ta.lowest(longPullbackDistance, pullbackLookback) <= 0
shortPullbackTouched = ta.highest(shortPullbackDistance, pullbackLookback) >= 0

longSetup = false
shortSetup = false

if emaBullStructure
    if longPricePosition
        if longPullbackTouched
            longSetup := true

if emaBearStructure
    if shortPricePosition
        if shortPullbackTouched
            shortSetup := true

//====================================================
// Trigger Conditions
//====================================================

longEmaRecross = false
shortEmaRecross = false

if close > emaFast
    if close[1] <= emaFast[1]
        longEmaRecross := true

if close < emaFast
    if close[1] >= emaFast[1]
        shortEmaRecross := true

longTriggerRaw = false
shortTriggerRaw = false

if longSetup
    if longEmaRecross
        if barstate.isconfirmed
            longTriggerRaw := true

if shortSetup
    if shortEmaRecross
        if barstate.isconfirmed
            shortTriggerRaw := true

//====================================================
// Cooldown
//====================================================

var int lastLongSignalBar = na
var int lastShortSignalBar = na

longCooldownOk = true
shortCooldownOk = true

if useCooldown
    longCooldownOk := false
    if na(lastLongSignalBar)
        longCooldownOk := true
    else
        if bar_index - lastLongSignalBar >= cooldownBars
            longCooldownOk := true

if useCooldown
    shortCooldownOk := false
    if na(lastShortSignalBar)
        shortCooldownOk := true
    else
        if bar_index - lastShortSignalBar >= cooldownBars
            shortCooldownOk := true

longSignal = false
shortSignal = false

if longTriggerRaw
    if longCooldownOk
        longSignal := true

if shortTriggerRaw
    if shortCooldownOk
        shortSignal := true

if longSignal
    lastLongSignalBar := bar_index

if shortSignal
    lastShortSignalBar := bar_index

//====================================================
// Risk Calculation at Signal Bar
//====================================================

longSignalSl = ta.lowest(low, riskLookback)
shortSignalSl = ta.highest(high, riskLookback)

longSignalRisk = close - longSignalSl
shortSignalRisk = shortSignalSl - close

longRiskValid = longSignalRisk > syminfo.mintick
shortRiskValid = shortSignalRisk > syminfo.mintick

minRisk = syminfo.mintick * minRiskTicks

longMinRiskOk = true
shortMinRiskOk = true

if useMinRiskFilter
    longMinRiskOk := false
    if longSignalRisk >= minRisk
        longMinRiskOk := true

if useMinRiskFilter
    shortMinRiskOk := false
    if shortSignalRisk >= minRisk
        shortMinRiskOk := true

//====================================================
// Store Planned Stop
//====================================================

var float plannedLongStop = na
var float plannedShortStop = na

//====================================================
// Entry
//====================================================

canEnter = strategy.position_size == 0

if longSignal
    if canEnter
        if longRiskValid
            if longMinRiskOk
                plannedLongStop := longSignalSl
                plannedShortStop := na
                strategy.entry("Long", strategy.long)

if shortSignal
    if canEnter
        if shortRiskValid
            if shortMinRiskOk
                plannedShortStop := shortSignalSl
                plannedLongStop := na
                strategy.entry("Short", strategy.short)

//====================================================
// Exit based on Actual Position Average Price
//====================================================

longPosition = strategy.position_size > 0
shortPosition = strategy.position_size < 0

longExitValid = false
shortExitValid = false

longEntryPrice = strategy.position_avg_price
shortEntryPrice = strategy.position_avg_price

float longActualRisk = na
float shortActualRisk = na

float longActualTp = na
float shortActualTp = na

if longPosition
    if not na(plannedLongStop)
        longActualRisk := longEntryPrice - plannedLongStop
        if longActualRisk > syminfo.mintick
            longActualTp := longEntryPrice + longActualRisk * rr
            longExitValid := true

if shortPosition
    if not na(plannedShortStop)
        shortActualRisk := plannedShortStop - shortEntryPrice
        if shortActualRisk > syminfo.mintick
            shortActualTp := shortEntryPrice - shortActualRisk * rr
            shortExitValid := true

invalidLongExit = false
invalidShortExit = false

if longPosition
    if not na(plannedLongStop)
        if not longExitValid
            invalidLongExit := true

if shortPosition
    if not na(plannedShortStop)
        if not shortExitValid
            invalidShortExit := true

if longExitValid
    strategy.exit("Long Exit", from_entry = "Long", stop = plannedLongStop, limit = longActualTp)

if shortExitValid
    strategy.exit("Short Exit", from_entry = "Short", stop = plannedShortStop, limit = shortActualTp)

if invalidLongExit
    strategy.close("Long", comment = "Invalid Long Risk")

if invalidShortExit
    strategy.close("Short", comment = "Invalid Short Risk")

//====================================================
// Reset Planned Stops After Position Closed
//====================================================

if strategy.position_size == 0
    if strategy.position_size[1] != 0
        plannedLongStop := na
        plannedShortStop := na

//====================================================
// Setup Background
//====================================================

bgColorValue = color.new(color.white, 100)

if showSetupBg
    if longSetup
        bgColorValue := color.new(color.green, 88)
    if shortSetup
        bgColorValue := color.new(color.red, 88)

bgcolor(bgColorValue)

//====================================================
// Trigger Signals
//====================================================

plotshape(showSignals and longSignal, title = "Long Trigger", style = shape.triangleup, location = location.belowbar, color = color.lime, size = size.small, text = "L")
plotshape(showSignals and shortSignal, title = "Short Trigger", style = shape.triangledown, location = location.abovebar, color = color.red, size = size.small, text = "S")

//====================================================
// Alerts
//====================================================

alertcondition(longSignal, title = "Long Trigger", message = "EMA Structure Pullback Strategy v1.2 Long Trigger")
alertcondition(shortSignal, title = "Short Trigger", message = "EMA Structure Pullback Strategy v1.2 Short Trigger")
